# Copy values into your shell or GitHub Actions secrets. Do not commit .env.
DEEPSEEK_API_KEY=replace-me
SCREENING_MODEL=deepseek-v4-flash
REVIEW_MODEL=deepseek-v4-pro
SITE_URL=http://127.0.0.1:8000
ARXIV_CATEGORIES=stat.ML,cs.LG,physics.data-an,hep-ex
MAX_CANDIDATES=60
BOOTSTRAP_RESULTS=120
METHOD_CANDIDATE_SLOTS=40
HEP_APPLICATION_SLOTS=10
DISCOVERY_SLOTS=10
MAX_DEEP_REVIEWS=5
MIN_DEEP_REVIEWS=3
PUBLISH_THRESHOLD=0.55
REVIEW_THRESHOLD=0.45
FEEDBACK_REPOSITORY=your-name/hepml-digest
